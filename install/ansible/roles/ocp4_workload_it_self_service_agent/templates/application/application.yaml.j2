---
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ ocp4_workload_it_self_service_agent_app_application_name }}
  namespace: {{ ocp4_workload_it_self_service_agent_app_application_namespace }}
  finalizers:
    - resources-finalizer.argocd.argoproj.io/foreground
spec:
  destination:
    name: ""
    namespace: {{ ocp4_workload_it_self_service_agent_app_namespace }}
    server: 'https://kubernetes.default.svc'
  project: default
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    retry:
      backoff:
        duration: 5s
        factor: 2
        maxDuration: 3m0s
      limit: 10
    syncOptions:
      - RespectIgnoreDifferences=true
  source:
    repoURL: {{ ocp4_workload_it_self_service_agent_app_gitops_repo }}
    targetRevision: {{ ocp4_workload_it_self_service_agent_app_gitops_repo_tag }}
    path: {{ ocp4_workload_it_self_service_agent_app_gitops_repo_path }}
    helm:
      valuesObject:
        servicenowMcp:
          source:
            helm:
              values:
                route:
                  host: servicenow-mcp.{{ r_openshift_subdomain }}
                servicenow:
                  apiKey: {{ ocp4_workload_it_self_service_agent_servicenow_api_key }}
                  laptopRefreshId: test
